modules = ["python-3.12"]

run = "uvicorn app.main:app --host 0.0.0.0 --port $PORT"

[deployment]
run = ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port $PORT"]
deploymentTarget = "autoscale"

[nix]
packages = ["libxcrypt", "postgresql"]
channel = "stable-25_05"

[userenv]

[userenv.shared]
