# Copy to .env and fill in. The app reads these automatically (app/config.py).

# --- Database ---
# Default (no setup): local SQLite file.
DATABASE_URL=sqlite:///./bakaya.db
# For real Postgres (Neon example) — MUST be a SEPARATE database from the TS app:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- LLM drafting ---
# Without this, drafts fall back to a template (app still works).
GROQ_API_KEY=

# --- Email ---
EMAIL_MODE=simulation        # set to "real" to actually send via Gmail SMTP
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
DEMO_RECIPIENT_EMAIL=        # redirect all notices to one inbox during demos
